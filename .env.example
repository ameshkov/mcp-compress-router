# MCP Compress Router — environment variables template.
# Copy this file to .env and fill in real values. .env is gitignored.
#
# Router runtime variables (all optional):
# MCP_COMPRESS_ROUTER_HOME=.   # directory containing mcp.json / mcp.jsonc
# MCP_COMPRESS_ROUTER_VERBOSE=true
# MCP_COMPRESS_ROUTER_LOGIN_TIMEOUT_MS=120000
#
# Place this file in the configuration directory (next to mcp.json /
# mcp.jsonc). Set MCP_COMPRESS_ROUTER_HOME to choose it explicitly;
# otherwise the platform default is used:
#   Linux:   ~/.local/share/mcp-compress-router/
#   macOS:   ~/Library/Application Support/mcp-compress-router/
#   Windows: %APPDATA%\mcp-compress-router\
#
# Example secrets referenced by mcp.example.jsonc via ${VAR}:
GITHUB_PERSONAL_TOKEN=ghp_your_token_here
MY_SERVER_TOKEN=your_token_here
